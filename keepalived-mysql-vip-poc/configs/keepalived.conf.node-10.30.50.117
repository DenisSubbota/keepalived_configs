! Keepalived configuration for MySQL VIPs (example)
! Node: 10.30.50.117

global_defs {
    enable_script_security
    script_user root
}

! Writer: Node must be primary (read_only=0 && not replica or with flag --allow-primary-as-replica ).
! On writer failure means:
! - VIP - removed if no healthy candidates [Default]
! - VIP - Sticky to node if "weight 5" uncommented - only priority changes.

vrrp_script chk_mysql_writer {
    script "/etc/keepalived/check_mysql.sh --primary --allow-primary-as-replica"
    interval 5
    rise 2
    fall 2
    ! weight 5
}

! Reader: node must be healthy replica (read_only=1, IO/SQL running, lag under threshold).
vrrp_script chk_mysql_reader {
    script "/etc/keepalived/check_mysql.sh --replica --max-lag 300"
    interval 5
}

! Writer-or-reader: node OK if it is either healthy writer (primary) OR healthy reader (replica) (Reader VIP fallback).
! Pass same options as above so both roles are evaluated with your thresholds:
!   --allow-primary-as-replica  allow primary even when configured as replica (matches writer check)
!   --max-lag N                 max lag for replica branch (matches reader check)

vrrp_script chk_mysql_writer_or_reader {
    script "/etc/keepalived/check_mysql.sh --writer-or-reader --allow-primary-as-replica --max-lag 300"
    interval 5
}

# Writer VIP
vrrp_instance VI_MYSQL_WRITER {
    state MASTER
    interface eth0
    virtual_router_id 51
    priority 10
    advert_int 1
    unicast_src_ip 10.30.50.117
    unicast_peer {
        10.30.50.115
    }

    authentication {
        auth_type PASS
        auth_pass MySecret123
    }

    virtual_ipaddress {
        192.168.88.18/32
    }

    track_script {
        chk_mysql_writer
    }

    notify_master "/etc/keepalived/keepalived_mysql_prom_handler.sh --status ok --vip 192.168.88.18 --role writer --cluster mycluster"
    notify_fault "/etc/keepalived/keepalived_mysql_prom_handler.sh --status fail --vip 192.168.88.18 --role writer --cluster mycluster"
}

# Reader VIP
vrrp_instance VI_MYSQL_READER {
    state BACKUP
    interface eth0
    virtual_router_id 52
    priority 10
    advert_int 1
    unicast_src_ip 10.30.50.117
    unicast_peer {
        10.30.50.115
    }

    authentication {
        auth_type PASS
        auth_pass MySecret123
    }

    virtual_ipaddress {
        192.168.88.19/32
    }

    ! Eligibility: node must pass chk_mysql_writer_or_reader (healthy as writer or reader).
    ! Priority boost: writer +5, reader +10 — replica preferred for Reader VIP when both are healthy.
    track_script {
        chk_mysql_writer weight 5
        chk_mysql_reader weight 10
        chk_mysql_writer_or_reader
    }

    notify_master "/etc/keepalived/keepalived_mysql_prom_handler.sh --status ok --vip 192.168.88.19 --role reader --cluster mycluster"
    notify_fault "/etc/keepalived/keepalived_mysql_prom_handler.sh --status fail --vip 192.168.88.19 --role reader --cluster mycluster"
}

